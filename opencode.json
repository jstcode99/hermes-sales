{
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter/stepfun/step-3.5-flash:free",
  "default_agent": "task-orchestrator",
  "provider": {
    "openrouter": {
      "name": "OpenRouter",
      "api": "https://openrouter.ai/api/v1"
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "tools": {
    "linear_*": true,
    "supabase_*": true,
    "context7_*": true,
    "shadcn_*": true
  },
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": ["bunx", "shadcn@latest", "mcp"],
      "enabled": true
    }
  }
}
